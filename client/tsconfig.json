{
  "extends": ["expo/tsconfig.base", "../tsconfig.base.json"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "target": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@event-finder/shared": ["../shared/types/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "nativewind-env.d.ts"],
  "exclude": ["components/ui", "components/screens", "legacy-frontend"]
}
