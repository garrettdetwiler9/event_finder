{
  "extends": ["expo/tsconfig.base", "../tsconfig.base.json"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "target": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "nativewind-env.d.ts"]
}
