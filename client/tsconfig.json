{
  "extends": ["expo/tsconfig.base", "../tsconfig.base.json"],
  "compilerOptions": {
    // Expo Router requires bundler module resolution
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "target": "ESNext",

    // Path alias — lets you import from @/components instead of ../../components
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"]
}
