# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Found in Atlas → Database → Connect → Drivers
MONGODB_URI=

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Service Accounts → Generate new private key
# Base64-encode the entire downloaded JSON file — do NOT commit the JSON file itself
#   Mac/Linux: base64 -i service-account.json | tr -d '\n'
#   Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Server-side key (no referrer restrictions) — separate from the client key
GOOGLE_MAPS_API_KEY=
