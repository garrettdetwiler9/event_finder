{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],

    // Input / output
    // rootDir is set to the monorepo root so TypeScript can include shared/types
    // (which lives outside server/src). outDir is still server/dist, so compiled
    // output lands at dist/server/src/... — update the start script accordingly.
    "rootDir": "../..",
    "outDir": "./dist",

    // Interop — required for default imports (express, dotenv, etc.)
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Type checking — matches tsconfig.base.json strict settings
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    // Module handling
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Needed for Express decorators if you add them later
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts", "../../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
