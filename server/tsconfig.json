{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],

    // Input / output
    "rootDir": "./src",
    "outDir": "./dist",

    // Interop — required for default imports (express, dotenv, etc.)
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Type checking — matches tsconfig.base.json strict settings
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    // Module handling
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Needed for Express decorators if you add them later
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Path alias — lets the server import from @event-finder/shared without
    // relying solely on the npm workspace symlink for TypeScript resolution.
    "baseUrl": ".",
    "paths": {
      "@event-finder/shared": ["../shared/types/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
