{
  "name": "event-finder",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "client": "cd client && expo start",
    "server": "npm run dev --workspace=server",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "android": "cd client && expo start --android",
    "ios": "cd client && expo start --ios",
    "tunnel": "cd client && expo start --tunnel",
    "tunnel:clean": "cd client && expo start --tunnel --clear"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,prettierrc}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-dev-client": "~6.0.21",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
