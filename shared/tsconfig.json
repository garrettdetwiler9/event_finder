{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    // Emit declaration files so client and server can consume shared types
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist"
  },
  "include": ["types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
